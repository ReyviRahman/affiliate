# Use alphanumeric values so they remain valid inside DATABASE_URL.
POSTGRES_USER=affiliate
POSTGRES_PASSWORD=change_this_to_a_long_random_alphanumeric_secret
POSTGRES_DB=affiliate

# Only required when the app is run directly with npm instead of Docker Compose.
DATABASE_URL="postgresql://affiliate:change_this_to_a_long_random_alphanumeric_secret@localhost:5432/affiliate?schema=public"

# WooCommerce REST API. Keep the consumer key and secret server-only.
WOOCOMMERCE_URL="https://yantotanjung.com"
WOOCOMMERCE_CONSUMER_KEY="ck_replace_with_read_only_key"
WOOCOMMERCE_CONSUMER_SECRET="cs_replace_with_read_only_secret"
